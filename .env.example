# Environment Variables

# Database
# Connect to Supabase via connection pooling
DATABASE_URL=""

# Direct connection to the database. Used for migrations
DIRECT_URL=""

# Next Auth
# For local development: http://localhost:3000
# For production: https://devproof-seven.vercel.app
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# GitHub OAuth
# Callback URL for GitHub App:
# Local: http://localhost:3000/api/auth/callback/github
# Production: https://devproof-seven.vercel.app/api/auth/callback/github
GITHUB_ID="your-github-id"
GITHUB_SECRET="your-github-secret"
GITHUB_TOKEN="your-personal-access-token"

# AI
GEMINI_API_KEY="your-gemini-api-key"

# Email / Google SMTP
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-google-app-password"
EMAIL_FROM="DevProof <noreply@devproof.com>"

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_HOST="https://us.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY="YOUR_POSTHOG_API_KEY"
