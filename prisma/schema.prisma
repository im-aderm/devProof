generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- NextAuth Models ---

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  githubId            String?   @unique
  username            String?   @unique
  bio                 String?
  onboardingCompleted Boolean   @default(false)
  isAdmin             Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  reports             Report[]
  snapshots           Snapshot[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- DevProof Business Models ---

model Report {
  id        String   @id @default(cuid())
  userId    String
  type      String   // profile, compare, repo, review
  targetA   String   // primary username or repo name
  targetB   String?  // secondary for comparisons
  score     Int?
  summary   String?  @db.Text
  payload   Json     // Standard Json for Postgres
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Snapshot {
  id              String   @id @default(cuid())
  userId          String
  stars           Int
  repos           Int
  followers       Int
  languages       Json     // Standard Json for Postgres
  activityScore   Int
  timestamp       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ExportLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // pdf, csv, json, docx
  fileName  String
  createdAt DateTime @default(now())
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
