// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  password            String?
  image               String?
  githubUsername      String?   @unique
  isAdmin             Boolean   @default(false)
  onboardingCompleted Boolean   @default(false)
  onboardingGoal      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  githubProfile GitHubProfile?
  repositories  Repository[]
  aiReports     AIReport[]
  readiness     ReadinessScore?
  resume        ResumeProfile?
  notifications Notification[]
  auditLogs     AuditLog[]
  subscription  Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GitHubProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  bio            String?
  publicRepos    Int      @default(0)
  followers      Int      @default(0)
  following      Int      @default(0)
  location       String?
  company        String?
  blog           String?
  twitter        String?
  isPublic       Boolean  @default(true)
  portfolioTheme String   @default("indigo")
  lastSyncedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Repository {
  id            String   @id @default(cuid())
  userId        String
  githubId      Int      @unique
  name          String
  fullName      String
  description   String?
  url           String
  homepage      String?
  stars         Int      @default(0)
  forks         Int      @default(0)
  language      String?
  isPrivate     Boolean  @default(false)
  pushedAt      DateTime
  createdAt     DateTime
  updatedAt     DateTime
  lastAnalyzedAt DateTime?

  metrics   RepositoryMetric?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  languages RepositoryLanguage[]
}

model RepositoryLanguage {
  id           String     @id @default(cuid())
  repositoryId String
  name         String
  size         Int
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, name])
}

model RepositoryMetric {
  id             String     @id @default(cuid())
  repositoryId   String     @unique
  readmeScore    Int?
  complexity     Int?
  freshness      Int?
  stackDetection Json?
  suggestions    Json?
  repository     Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
}

model AIReport {
  id               String   @id @default(cuid())
  userId           String
  type             String   // e.g., "USER_SUMMARY", "REPO_SUMMARY"
  content          String   @db.Text
  confidenceScore  Float    @default(0.0)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReadinessScore {
  id              String   @id @default(cuid())
  userId          String   @unique
  overallScore    Int
  projectQuality  Int
  consistency     Int
  collaboration   Int
  documentation   Int
  technicalBreadth Int
  recommendations Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResumeProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   Json
  template  String   @default("modern")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SyncLog {
  id        String   @id @default(cuid())
  userId    String
  status    String   // SUCCESS, FAILED, IN_PROGRESS
  error     String?
  startedAt DateTime @default(now())
  endedAt   DateTime?
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  plan            String   // e.g., "free", "pro", "team"
  status          String   // e.g., "active", "canceled", "past_due"
  stripeCustomerId String? @map("stripe_customer_id")
  stripeSubId     String? @map("stripe_subscription_id")
  currentPeriodEnd DateTime? @map("current_period_end")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
